{
  "name": "sera-properties",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "android:local": "powershell -ExecutionPolicy Bypass -File ./scripts/android-start.ps1",
    "android:check": "powershell -ExecutionPolicy Bypass -File ./scripts/android-start.ps1 -ValidateOnly",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas:configure": "npx eas build:configure",
    "build:android": "npx eas build -p android --profile preview",
    "build:android:prod": "npx eas build -p android --profile production",
    "build:ios": "npx eas build -p ios --profile production",
    "submit:android": "npx eas submit -p android",
    "submit:ios": "npx eas submit -p ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~55.0.4",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eas-cli": "^18.0.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
